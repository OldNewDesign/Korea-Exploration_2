# Copy to .env and `source .env`, or export these in your shell.

# Enables AI translation/summarization/categorization. Without it the pipeline
# still runs and stores raw metadata/transcripts (flagged "needs review").
export ANTHROPIC_API_KEY=""

# Optional overrides:
# export VIP_MODEL="claude-sonnet-4-6"        # any model you have access to
# export VIP_WHISPER_MODEL="small"            # tiny|base|small|medium|large-v3|turbo
# export VIP_GUIDE_TITLE="Korea & Seoul"

# Google Maps: if set, the map renders with Google Maps AND geocoding uses
# Google (better for messy/Korean addresses). Without it, the map falls back to
# OpenStreetMap (free, no key). Enable BOTH "Maps JavaScript API" and
# "Geocoding API" for this key in the Google Cloud console.
export GOOGLE_MAPS_API_KEY=""
# Force a provider regardless of the key ("auto" | "google" | "osm"):
# export VIP_GEO_PROVIDER="auto"
# export VIP_MAP_PROVIDER="auto"
