# Copy this file to ".env" (no .example) and fill in your keys.
# The app and CLI load .env automatically. .env is gitignored, so keys stay private.

# Recommended: enables translation + smart categories.
ANTHROPIC_API_KEY=

# Optional: better geocoding for Korean addresses (also lets the in-app map use Google).
# The published/shared map always uses OpenStreetMap regardless, so no key is ever published.
GOOGLE_MAPS_API_KEY=

# Optional overrides (uncomment to change):
# VIP_MODEL=claude-sonnet-4-6
# VIP_WHISPER_MODEL=small
# VIP_GUIDE_TITLE=Korea & Seoul
